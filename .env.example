# OPENAI_API_KEY: Required for OpenAI API calls (Chat Completions + JSON schema).
# Loaded via Vite and exposed to the client as import.meta.env.VITE_OPENAI_API_KEY — use a backend proxy in production.
OPENAI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
